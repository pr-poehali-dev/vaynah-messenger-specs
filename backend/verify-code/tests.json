{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Reject wrong code",
      "method": "POST",
      "path": "/",
      "body": {"email": "test@mail.ru", "code": "0000"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Неверный код. Проверьте письмо и попробуйте снова."},
      "bodyMatcher": "partial"
    },
    {
      "name": "Reject empty body",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": {"error": "Укажите email и код"},
      "bodyMatcher": "partial"
    }
  ]
}
